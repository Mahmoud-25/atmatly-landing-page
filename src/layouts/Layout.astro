---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Atmatly – Business Automation for Saudi SMEs",
  description = "Smart automation systems for Saudi businesses to reduce manual work, improve efficiency, and scale faster.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Inter (English) + Cairo (Arabic) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Cairo:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/logo.png" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
    <!-- Runs BEFORE paint to avoid language flash -->
    <script is:inline>
      (function () {
        var lang = localStorage.getItem('atmatly-lang') || 'en';
        document.documentElement.lang = lang;
        document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
      })();
    </script>
  </head>
  <body class="bg-white text-slate-900 antialiased">
    <slot />
    <script is:inline>
      /* Global language switcher — called from Navbar buttons */
      function switchLanguage(lang) {
        document.documentElement.lang = lang;
        document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
        localStorage.setItem('atmatly-lang', lang);
      }
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', function (user) {
          if (!user) {
            window.netlifyIdentity.on('login', function () {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </body>
</html>
