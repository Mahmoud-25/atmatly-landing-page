---
const steps = [
  {
    en: { title: 'We Understand Your Process', desc: 'We start with a free 30-minute strategy call to deeply understand your business workflows, bottlenecks, and automation goals.' },
    ar: { title: 'نفهم عملياتك التجارية', desc: 'نبدأ بمكالمة استراتيجية مجانية مدتها 30 دقيقة لفهم سير عمل شركتك ونقاط الألم وأهداف الأتمتة بعمق.' },
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />`,
  },
  {
    en: { title: 'We Design & Build The Automation', desc: 'Our team designs a custom automation system and builds it precisely for your tools, team, and business processes.' },
    ar: { title: 'نصمم ونبني الأتمتة', desc: 'يصمم فريقنا نظام أتمتة مخصص وينفذه بدقة لأدواتك وفريقك وعمليات عملك.' },
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`,
  },
  {
    en: { title: 'You Save Time & Focus on Growth', desc: 'Once live, your automation runs 24/7 handling repetitive tasks — so you can focus on growing your business.' },
    ar: { title: 'توفر الوقت وتركز على النمو', desc: 'بمجرد تشغيله، يعمل نظام الأتمتة 24/7 للتعامل مع المهام المتكررة — حتى تتمكن من التركيز على تنمية عملك.' },
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
  },
];
---

<section id="how-it-works" class="py-24" style="background: linear-gradient(180deg, #f0fdf4 0%, #f8fafc 100%);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <div class="inline-flex items-center px-3 py-1 bg-emerald-100 text-emerald-700 text-sm font-semibold rounded-full mb-4">
        <span data-lang="en">Simple Process</span><span data-lang="ar">عملية بسيطة</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
        <span data-lang="en">How It Works</span>
        <span data-lang="ar">كيف نعمل</span>
      </h2>
      <p class="text-lg text-slate-500 max-w-xl mx-auto">
        <span data-lang="en">From your first call to a live automation system — clear, fast, and hassle-free.</span>
        <span data-lang="ar">من مكالمتك الأولى إلى نظام أتمتة حي — بوضوح وسرعة وبدون تعقيد.</span>
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 relative">
      <div class="hidden md:block absolute top-16 left-1/3 right-1/3 h-0.5 bg-gradient-to-r from-emerald-200 via-emerald-400 to-emerald-200 -z-0"></div>

      {steps.map((step, i) => (
        <div class="relative flex flex-col items-center text-center group">
          <div class="relative z-10 w-20 h-20 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-105 transition-transform duration-300"
            style="background: linear-gradient(135deg, #059669, #10b981);">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={step.icon} />
            <div class="absolute -top-2 -right-2 w-6 h-6 bg-white rounded-full flex items-center justify-center text-xs font-bold text-emerald-700 shadow-md border border-emerald-100">
              {i + 1}
            </div>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">
            <span data-lang="en">{step.en.title}</span>
            <span data-lang="ar">{step.ar.title}</span>
          </h3>
          <p class="text-slate-500 text-sm leading-relaxed max-w-xs">
            <span data-lang="en">{step.en.desc}</span>
            <span data-lang="ar">{step.ar.desc}</span>
          </p>
        </div>
      ))}
    </div>

    <div class="mt-14 text-center">
      <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 bg-emerald-600 text-white font-bold rounded-xl hover:bg-emerald-700 transition-all duration-200 shadow-lg shadow-emerald-600/25 hover:-translate-y-0.5 text-sm">
        <span data-lang="en">Start Your Free Strategy Call</span>
        <span data-lang="ar">ابدأ مكالمتك الاستراتيجية المجانية</span>
        <svg class="w-5 h-5 arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
