---
interface Props {
  email?: string;
  whatsapp?: string;
}
const { email = 'hello@atmatly.com', whatsapp } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-400 py-14">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-10 mb-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <img src="/logo.png" alt="Atmatly" style="width:32px;height:32px;display:block;flex-shrink:0;" />
          <span class="font-bold text-slate-300 text-base" data-lang="en">Atmatly</span>
          <span class="font-bold text-slate-300 text-base" data-lang="ar" style="font-family:'Cairo',sans-serif;">أتمتلي</span>
        </a>
        <p class="text-sm leading-relaxed text-slate-400 max-w-xs">
          <span data-lang="en">Building smart automation systems for Saudi businesses to scale faster, reduce manual work, and grow smarter.</span>
          <span data-lang="ar">نبني أنظمة أتمتة ذكية للشركات السعودية لتنمو أسرع، وتقلل العمل اليدوي، وتعمل بذكاء أكبر.</span>
        </p>
        <div class="flex items-center gap-3 mt-5">
          <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-slate-800 rounded-lg text-xs text-slate-300 border border-slate-700">
            🇸🇦 <span data-lang="en">Saudi Market</span><span data-lang="ar">السوق السعودي</span>
          </span>
          <span class="inline-flex items-center px-2.5 py-1 bg-slate-800 rounded-lg text-xs text-slate-300 border border-slate-700">
            AR / EN
          </span>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-5 text-sm tracking-wide">
          <span data-lang="en">Quick Links</span>
          <span data-lang="ar">روابط سريعة</span>
        </h4>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="#services" class="hover:text-emerald-400 transition-colors">
              <span data-lang="en">Services</span><span data-lang="ar">خدماتنا</span>
            </a>
          </li>
          <li>
            <a href="#how-it-works" class="hover:text-emerald-400 transition-colors">
              <span data-lang="en">How It Works</span><span data-lang="ar">كيف نعمل</span>
            </a>
          </li>
          <li>
            <a href="#packages" class="hover:text-emerald-400 transition-colors">
              <span data-lang="en">Packages</span><span data-lang="ar">الباقات</span>
            </a>
          </li>
          <li>
            <a href="#why-us" class="hover:text-emerald-400 transition-colors">
              <span data-lang="en">Why Us</span><span data-lang="ar">لماذا نحن</span>
            </a>
          </li>
          <li>
            <a href="#contact" class="hover:text-emerald-400 transition-colors">
              <span data-lang="en">Contact</span><span data-lang="ar">تواصل معنا</span>
            </a>
          </li>
          <li>
            <a href="/admin" class="hover:text-slate-300 transition-colors text-slate-600 text-xs">
              <span data-lang="en">Admin Dashboard</span>
              <span data-lang="ar">لوحة التحكم</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold mb-5 text-sm tracking-wide">
          <span data-lang="en">Contact</span>
          <span data-lang="ar">تواصل معنا</span>
        </h4>
        <ul class="space-y-3 text-sm">
          {email && (
            <li>
              <a
                href={`mailto:${email}`}
                class="flex items-center gap-2.5 hover:text-emerald-400 transition-colors"
              >
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                {email}
              </a>
            </li>
          )}
          {whatsapp && (
            <li>
              <a
                href={`https://wa.me/${whatsapp.replace(/\D/g, '')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2.5 hover:text-emerald-400 transition-colors"
              >
                <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
                </svg>
                {whatsapp}
              </a>
            </li>
          )}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-slate-600">
      <p>© {year} Atmatly. <span data-lang="en">All rights reserved.</span><span data-lang="ar">جميع الحقوق محفوظة.</span></p>
      <p>
        <span data-lang="en">Automation Solutions · Saudi Arabia · Arabic &amp; English</span>
        <span data-lang="ar">حلول الأتمتة · المملكة العربية السعودية · عربي وإنجليزي</span>
      </p>
    </div>
  </div>
</footer>
